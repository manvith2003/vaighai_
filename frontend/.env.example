# --- Frontend / Vercel environment ---

# Access-gate password (client-side barrier). Set the SAME value in Vercel project env.
# Note: VITE_ vars are embedded in the built JS, so this is a light barrier for a
# confidential internal page, not hard security. Share it with the reviewer separately.
VITE_SITE_PASSWORD=change-me

# --- Server-side only (set these in the Vercel dashboard, NOT with a VITE_ prefix) ---
# Used by the /api serverless functions; never shipped to the browser.
# LLM_API_KEY=gsk_your_groq_key
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
