# Copy to .env, or export these in your shell before running the pipeline.

# ------------------------------------------------------------------ warehouse
# LEAVE EMPTY -> SQLite (zero setup, default).
# FOR POSTGRES (after `docker compose up -d`), uncomment the second line:
WAREHOUSE_URL=
# WAREHOUSE_URL=postgresql+psycopg2://radar:radar@localhost:5432/supplyradar

# ------------------------------------------------------------------ LLM agent
# LEAVE EMPTY -> offline template mode.
# For LLM-written briefs: free key from https://console.groq.com (starts gsk_)
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
# Fully in-house alternative (privacy rule): run Ollama and use
# LLM_BASE_URL=http://localhost:11434/v1  LLM_MODEL=llama3.1

# ------------------------------------------------------------------ weather
# History window for model training (fiscal year start recommended)
WEATHER_START=2020-04-01
