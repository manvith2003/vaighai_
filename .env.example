# Copy to .env and export, or set these in your shell / n8n / cron environment.

# Warehouse backend — leave empty for SQLite (zero setup), or point at Postgres:
# WAREHOUSE_URL=postgresql+psycopg2://radar:radar@localhost:5432/supplyradar
WAREHOUSE_URL=

# LLM for the agent brief — leave empty for offline template mode.
# Free-tier options: Groq (console.groq.com, default base URL) or any
# OpenAI-compatible endpoint (OpenRouter, Ollama at http://localhost:11434/v1, ...)
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Weather extraction history window (training needs history, not just today)
WEATHER_START=2020-04-01
